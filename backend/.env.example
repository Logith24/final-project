# Copy to .env locally (never commit .env)

# Server port (Render sets PORT automatically — you usually do not set it on Render)
PORT=5000

# MongoDB connection string
# Local: mongodb://127.0.0.1:27017/library
# Atlas: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/library?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/library

# Allowed browser origin(s) for CORS (comma-separated for multiple)
# Local React: http://localhost:3000
# GitHub Pages: https://YOUR_USERNAME.github.io
FRONTEND_URL=http://localhost:3000

# Optional
NODE_ENV=development
